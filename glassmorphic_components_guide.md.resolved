## 5. Glass Modal Component

```tsx
// packages/react/src/components/glassmorphic/glass-modal/glass-modal.tsx

import * as React from 'react';
import { createPortal } from 'react-dom';
import { X } from 'lucide-react';
import { cn } from '@/lib/utils';
import { GlassCard } from '../glass-card';
import { GlassButton } from '../glass-button';

interface GlassModalProps {
  open: boolean;
  onOpenChange: (open: boolean) => void;
  title?: string;
  description?: string;
  children?: React.ReactNode;
  size?: 'sm' | 'md' | 'lg' | 'xl' | 'full';
  closeOnOverlayClick?: boolean;
  showCloseButton?: boolean;
}

export function GlassModal({
  open,
  onOpenChange,
  title,
  description,
  children,
  size = 'md',
  closeOnOverlayClick = true,
  showCloseButton = true,
}: GlassModalProps) {
  // Lock body scroll when open
  React.useEffect(() => {
    if (open) {
      document.body.style.overflow = 'hidden';
    } else {
      document.body.style.overflow = '';
    }
    return () => {
      document.body.style.overflow = '';
    };
  }, [open]);
  
  // Handle escape key
  React.useEffect(() => {
    const handleEscape = (e: KeyboardEvent) => {
      if (e.key === 'Escape') onOpenChange(false);
    };
    
    if (open) {
      document.addEventListener('keydown', handleEscape);
    }
    
    return () => document.removeEventListener('keydown', handleEscape);
  }, [open, onOpenChange]);
  
  if (!open) return null;
  
  const sizeClasses = {
    sm: 'max-w-sm',
    md: 'max-w-md',
    lg: 'max-w-lg',
    xl: 'max-w-xl',
    full: 'max-w-[90vw]',
  };
  
  return createPortal(
    <div
      className={cn(
        'fixed inset-0 z-50',
        'flex items-center justify-center p-4'
      )}
      role="dialog"
      aria-modal="true"
      aria-labelledby={title ? 'modal-title' : undefined}
    >
      {/* Backdrop */}
      <div
        className={cn(
          'absolute inset-0',
          'bg-black/60 backdrop-blur-sm',
          'animate-in fade-in duration-200'
        )}
        onClick={() => closeOnOverlayClick && onOpenChange(false)}
        aria-hidden="true"
      />
      
      {/* Modal Content */}
      <GlassCard
        variant="glow"
        blur="xl"
        className={cn(
          'relative z-10 w-full',
          sizeClasses[size],
          'animate-in zoom-in-95 fade-in duration-200'
        )}
      >
        {/* Close Button */}
        {showCloseButton && (
          <GlassButton
            size="icon"
            variant="ghost"
            className="absolute top-4 right-4"
            onClick={() => onOpenChange(false)}
            aria-label="Close modal"
          >
            <X className="h-4 w-4" />
          </GlassButton>
        )}
        
        {/* Header */}
        {(title || description) && (
          <div className="mb-4">
            {title && (
              <h2
                id="modal-title"
                className="text-xl font-semibold text-white"
              >
                {title}
              </h2>
            )}
            {description && (
              <p className="mt-1 text-sm text-white/60">
                {description}
              </p>
            )}
          </div>
        )}
        
        {/* Content */}
        <div>{children}</div>
      </GlassCard>
    </div>,
    document.body
  );
}
```

---

## 6. Accessibility Requirements

### 6.1 Glass Card
- Must be semantic (use appropriate heading levels)
- Sufficient color contrast for text
- Focus visible when interactive

### 6.2 Glass Button
- Full keyboard support (Enter, Space)
- Visible focus ring
- aria-disabled when loading
- aria-label for icon-only buttons

### 6.3 Glass Modal
- Focus trap when open
- Close on Escape key
- aria-modal="true"
- aria-labelledby for title
- Return focus to trigger on close

---

