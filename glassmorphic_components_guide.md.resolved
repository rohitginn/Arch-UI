## 3. Glass Card Component

### 3.1 React Implementation

```tsx
// packages/react/src/components/glassmorphic/glass-card/glass-card.tsx

import * as React from 'react';
import { cva, type VariantProps } from 'class-variance-authority';
import { cn } from '@/lib/utils';

const glassCardVariants = cva(
  // Base styles
  [
    'relative rounded-2xl overflow-hidden',
    'backdrop-blur-lg',
    'border border-white/10',
    'transition-all duration-200 ease-out',
  ].join(' '),
  {
    variants: {
      variant: {
        default: [
          'bg-white/5 dark:bg-white/5',
          'hover:bg-white/8 dark:hover:bg-white/8',
          'shadow-lg',
        ].join(' '),
        bordered: [
          'bg-white/5 dark:bg-white/5',
          'border-2 border-white/20',
          'hover:border-white/30',
        ].join(' '),
        gradient: [
          'bg-gradient-to-br from-white/10 to-white/5',
          'hover:from-white/15 hover:to-white/8',
        ].join(' '),
        glow: [
          'bg-white/5 dark:bg-white/5',
          'shadow-[0_0_30px_rgba(255,255,255,0.1)]',
          'hover:shadow-[0_0_40px_rgba(255,255,255,0.15)]',
        ].join(' '),
      },
      blur: {
        sm: 'backdrop-blur-sm',
        md: 'backdrop-blur-md',
        lg: 'backdrop-blur-lg',
        xl: 'backdrop-blur-xl',
      },
      size: {
        sm: 'p-4',
        md: 'p-6',
        lg: 'p-8',
        xl: 'p-10',
      },
    },
    defaultVariants: {
      variant: 'default',
      blur: 'lg',
      size: 'md',
    },
  }
);

export interface GlassCardProps
  extends React.HTMLAttributes<HTMLDivElement>,
    VariantProps<typeof glassCardVariants> {
  /** Enable hover animation */
  animated?: boolean;
  /** Show shine effect on hover */
  shine?: boolean;
}

const GlassCard = React.forwardRef<HTMLDivElement, GlassCardProps>(
  ({ className, variant, blur, size, animated, shine, children, ...props }, ref) => {
    return (
      <div
        ref={ref}
        className={cn(
          glassCardVariants({ variant, blur, size }),
          animated && 'hover:scale-[1.02] hover:-translate-y-1',
          shine && 'group',
          className
        )}
        {...props}
      >
        {/* Shine overlay */}
        {shine && (
          <div
            className={cn(
              'absolute inset-0 opacity-0 group-hover:opacity-100',
              'bg-gradient-to-r from-transparent via-white/10 to-transparent',
              'translate-x-[-100%] group-hover:translate-x-[100%]',
              'transition-all duration-700 ease-out'
            )}
            aria-hidden="true"
          />
        )}
        
        {/* Content */}
        <div className="relative z-10">
          {children}
        </div>
      </div>
    );
  }
);

GlassCard.displayName = 'GlassCard';

export { GlassCard, glassCardVariants };
```

### 3.2 Vue Implementation

```vue
<!-- packages/vue/src/components/glassmorphic/GlassCard.vue -->

<script setup lang="ts">
import { computed } from 'vue';
import { cn } from '@/lib/utils';

interface Props {
  variant?: 'default' | 'bordered' | 'gradient' | 'glow';
  blur?: 'sm' | 'md' | 'lg' | 'xl';
  size?: 'sm' | 'md' | 'lg' | 'xl';
  animated?: boolean;
  shine?: boolean;
  class?: string;
}

const props = withDefaults(defineProps<Props>(), {
  variant: 'default',
  blur: 'lg',
  size: 'md',
  animated: false,
  shine: false,
});

const classes = computed(() => {
  const baseClasses = [
    'relative rounded-2xl overflow-hidden',
    'backdrop-blur-lg',
    'border border-white/10',
    'transition-all duration-200 ease-out',
  ];
  
  const variantClasses = {
    default: 'bg-white/5 hover:bg-white/8 shadow-lg',
    bordered: 'bg-white/5 border-2 border-white/20 hover:border-white/30',
    gradient: 'bg-gradient-to-br from-white/10 to-white/5 hover:from-white/15',
    glow: 'bg-white/5 shadow-[0_0_30px_rgba(255,255,255,0.1)]',
  };
  
  const blurClasses = {
    sm: 'backdrop-blur-sm',
    md: 'backdrop-blur-md',
    lg: 'backdrop-blur-lg',
    xl: 'backdrop-blur-xl',
  };
  
  const sizeClasses = {
    sm: 'p-4',
    md: 'p-6',
    lg: 'p-8',
    xl: 'p-10',
  };
  
  return cn(
    baseClasses,
    variantClasses[props.variant],
    blurClasses[props.blur],
    sizeClasses[props.size],
    props.animated && 'hover:scale-[1.02] hover:-translate-y-1',
    props.shine && 'group',
    props.class
  );
});
</script>

<template>
  <div :class="classes">
    <!-- Shine overlay -->
    <div
      v-if="shine"
      class="absolute inset-0 opacity-0 group-hover:opacity-100
             bg-gradient-to-r from-transparent via-white/10 to-transparent
             translate-x-[-100%] group-hover:translate-x-[100%]
             transition-all duration-700 ease-out"
      aria-hidden="true"
    />
    
    <!-- Content -->
    <div class="relative z-10">
      <slot />
    </div>
  </div>
</template>
```

