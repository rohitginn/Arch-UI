## 4. Glass Button Component

### 4.1 React Implementation

```tsx
// packages/react/src/components/glassmorphic/glass-button/glass-button.tsx

import * as React from 'react';
import { cva, type VariantProps } from 'class-variance-authority';
import { cn } from '@/lib/utils';
import { Loader2 } from 'lucide-react';

const glassButtonVariants = cva(
  [
    // Base
    'relative inline-flex items-center justify-center',
    'font-medium rounded-xl',
    'backdrop-blur-md',
    'border border-white/20',
    'transition-all duration-200 ease-out',
    
    // Focus
    'focus-visible:outline-none focus-visible:ring-2',
    'focus-visible:ring-white/50 focus-visible:ring-offset-2',
    'focus-visible:ring-offset-transparent',
    
    // Disabled
    'disabled:opacity-50 disabled:pointer-events-none',
    
    // Active
    'active:scale-[0.98]',
  ].join(' '),
  {
    variants: {
      variant: {
        default: [
          'bg-white/10 hover:bg-white/20',
          'text-white',
        ].join(' '),
        primary: [
          'bg-blue-500/20 hover:bg-blue-500/30',
          'text-blue-100 border-blue-400/20',
        ].join(' '),
        success: [
          'bg-green-500/20 hover:bg-green-500/30',
          'text-green-100 border-green-400/20',
        ].join(' '),
        danger: [
          'bg-red-500/20 hover:bg-red-500/30',
          'text-red-100 border-red-400/20',
        ].join(' '),
        ghost: [
          'bg-transparent hover:bg-white/10',
          'text-white border-transparent',
        ].join(' '),
      },
      size: {
        sm: 'h-8 px-3 text-xs gap-1.5',
        md: 'h-10 px-4 text-sm gap-2',
        lg: 'h-12 px-6 text-base gap-2.5',
        xl: 'h-14 px-8 text-lg gap-3',
        icon: 'h-10 w-10',
      },
      glow: {
        true: 'hover:shadow-[0_0_20px_rgba(255,255,255,0.2)]',
        false: '',
      },
      magnetic: {
        true: '', // Handled by JS
        false: '',
      },
    },
    defaultVariants: {
      variant: 'default',
      size: 'md',
      glow: false,
      magnetic: false,
    },
  }
);

export interface GlassButtonProps
  extends React.ButtonHTMLAttributes<HTMLButtonElement>,
    VariantProps<typeof glassButtonVariants> {
  loading?: boolean;
  leftIcon?: React.ReactNode;
  rightIcon?: React.ReactNode;
}

const GlassButton = React.forwardRef<HTMLButtonElement, GlassButtonProps>(
  (
    {
      className,
      variant,
      size,
      glow,
      magnetic,
      loading,
      disabled,
      leftIcon,
      rightIcon,
      children,
      ...props
    },
    ref
  ) => {
    const buttonRef = React.useRef<HTMLButtonElement>(null);
    
    // Magnetic effect
    React.useEffect(() => {
      if (!magnetic) return;
      
      const button = buttonRef.current;
      if (!button) return;
      
      const handleMouseMove = (e: MouseEvent) => {
        const rect = button.getBoundingClientRect();
        const x = e.clientX - rect.left - rect.width / 2;
        const y = e.clientY - rect.top - rect.height / 2;
        
        button.style.transform = `translate(${x * 0.1}px, ${y * 0.1}px)`;
      };
      
      const handleMouseLeave = () => {
        button.style.transform = 'translate(0, 0)';
      };
      
      button.addEventListener('mousemove', handleMouseMove);
      button.addEventListener('mouseleave', handleMouseLeave);
      
      return () => {
        button.removeEventListener('mousemove', handleMouseMove);
        button.removeEventListener('mouseleave', handleMouseLeave);
      };
    }, [magnetic]);
    
    return (
      <button
        ref={(node) => {
          buttonRef.current = node;
          if (typeof ref === 'function') ref(node);
          else if (ref) ref.current = node;
        }}
        className={cn(
          glassButtonVariants({ variant, size, glow, magnetic }),
          className
        )}
        disabled={disabled || loading}
        {...props}
      >
        {/* Ripple effect layer */}
        <span className="absolute inset-0 overflow-hidden rounded-xl">
          <span className="ripple" />
        </span>
        
        {/* Content */}
        <span className="relative z-10 flex items-center gap-2">
          {loading ? (
            <Loader2 className="h-4 w-4 animate-spin" />
          ) : (
            leftIcon
          )}
          {children}
          {!loading && rightIcon}
        </span>
      </button>
    );
  }
);

GlassButton.displayName = 'GlassButton';

export { GlassButton, glassButtonVariants };
```

