{
  "name": "@archui/core",
  "version": "0.1.0",
  "description": "Core utilities, types, and design tokens for ArchUI",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./styles": {
      "import": "./dist/styles/index.css",
      "default": "./dist/styles/index.css"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && node -e \"const fs=require('node:fs');fs.mkdirSync('dist/styles',{recursive:true});fs.copyFileSync('src/styles/glass-tokens.css','dist/styles/glass-tokens.css');fs.copyFileSync('src/styles/glass-tokens.css','dist/styles/index.css');fs.copyFileSync('src/backgrounds/bg-tokens.css','dist/styles/bg-tokens.css');\"",
    "dev": "tsup --watch",
    "clean": "rimraf dist",
    "lint": "eslint src --ext .ts",
    "test": "vitest"
  },
  "dependencies": {
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.2.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "rimraf": "^5.0.5",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.2.2"
  },
  "peerDependencies": {
    "tailwindcss": ">=3.4.0"
  },
  "sideEffects": [
    "./dist/styles/*.css"
  ],
  "license": "MIT"
}