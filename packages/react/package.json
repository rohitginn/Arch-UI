{
  "name": "@archui/react",
  "version": "0.1.0",
  "description": "React components for ArchUI - Modern glassmorphic UI library",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./glassmorphic": {
      "types": "./dist/glassmorphic.d.ts",
      "import": "./dist/glassmorphic.mjs",
      "require": "./dist/glassmorphic.js"
    },
    "./backgrounds": {
      "types": "./dist/components/backgrounds/index.d.ts",
      "import": "./dist/components/backgrounds/index.mjs",
      "require": "./dist/components/backgrounds/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rimraf dist",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest"
  },
  "dependencies": {
    "@archui/core": "workspace:*",
    "class-variance-authority": "^0.7.0",
    "cobe": "^0.6.5"
  },
  "devDependencies": {
    "@testing-library/react": "^14.1.2",
    "@types/node": "^20.11.5",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "lucide-react": "^0.344.0",
    "motion": "^12.34.3",
    "rimraf": "^5.0.5",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.2.2"
  },
  "peerDependencies": {
    "lucide-react": ">=0.400.0",
    "motion": ">=11.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "tailwindcss": ">=3.4.0"
  },
  "peerDependenciesMeta": {
    "lucide-react": {
      "optional": true
    },
    "motion": {
      "optional": true
    }
  },
  "sideEffects": false,
  "license": "MIT"
}