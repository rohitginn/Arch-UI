{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "baseUrl": ".",
    "jsx": "react-jsx",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@archui/core": [
        "../../packages/core/src"
      ]
    }
  },
  "include": [
    "src/**/*",
    "../../packages/core/src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.tsx"
  ]
}