# ZenUI - Component Preview System
## Technical Implementation Guide

---

## 1. Preview System Overview

The component preview system allows users to:
- See live rendered components
- Switch between React/Vue/Next/Nuxt code
- Toggle light/dark themes
- Change viewport sizes (mobile/tablet/desktop)
- Copy code with one click
- Edit code and see live updates

---

## 2. Preview Container Component

```tsx
// apps/docs/src/components/preview/PreviewContainer.tsx

import { useState } from 'react';
import { PreviewToolbar } from './PreviewToolbar';
import { PreviewFrame } from './PreviewFrame';
import { CodeBlock } from './CodeBlock';

interface PreviewContainerProps {
  componentName: string;
  examples: {
    react: string;
    vue: string;
  };
  defaultProps?: Record<string, any>;
}

export function PreviewContainer({
  componentName,
  examples,
  defaultProps = {},
}: PreviewContainerProps) {
  // Preview State
  const [framework, setFramework] = useState<'react' | 'vue'>('react');
  const [theme, setTheme] = useState<'light' | 'dark'>('dark');
  const [viewport, setViewport] = useState<'mobile' | 'tablet' | 'desktop'>('desktop');
  const [isCodeVisible, setIsCodeVisible] = useState(true);
  const [editedCode, setEditedCode] = useState(examples[framework]);
  
  // Viewport sizes
  const viewportSizes = {
    mobile: { width: 375, height: 667 },
    tablet: { width: 768, height: 1024 },
    desktop: { width: '100%', height: 400 },
  };
  
  // Handle framework change
  const handleFrameworkChange = (newFramework: 'react' | 'vue') => {
    setFramework(newFramework);
    setEditedCode(examples[newFramework]);
  };
  
  return (
    <div className="preview-container rounded-xl border border-white/10 overflow-hidden">
      {/* Toolbar */}
      <PreviewToolbar
        framework={framework}
        onFrameworkChange={handleFrameworkChange}
        theme={theme}
        onThemeChange={setTheme}
        viewport={viewport}
        onViewportChange={setViewport}
        isCodeVisible={isCodeVisible}
        onToggleCode={() => setIsCodeVisible(!isCodeVisible)}
      />
      
      {/* Live Preview */}
      <div 
        className="preview-wrapper bg-gradient-to-br from-slate-900 to-slate-800 p-8"
        style={{
          display: 'flex',
          justifyContent: 'center',
          alignItems: 'center',
          minHeight: '300px',
        }}
      >
        <PreviewFrame
          code={editedCode}
          framework={framework}
          theme={theme}
          viewport={viewportSizes[viewport]}
        />
      </div>
      
      {/* Code Block */}
      {isCodeVisible && (
        <CodeBlock
          code={editedCode}
          language={framework === 'react' ? 'tsx' : 'vue'}
          onCodeChange={setEditedCode}
          showLineNumbers={true}
        />
      )}
    </div>
  );
}
```

