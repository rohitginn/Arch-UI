## 5. Code Block with Copy & Edit

```tsx
// apps/docs/src/components/preview/CodeBlock.tsx

import { useState } from 'react';
import { Check, Copy, Edit2 } from 'lucide-react';
import { Highlight, themes } from 'prism-react-renderer';

interface CodeBlockProps {
  code: string;
  language: 'tsx' | 'vue' | 'css' | 'bash';
  onCodeChange?: (code: string) => void;
  showLineNumbers?: boolean;
  editable?: boolean;
}

export function CodeBlock({
  code,
  language,
  onCodeChange,
  showLineNumbers = true,
  editable = false,
}: CodeBlockProps) {
  const [copied, setCopied] = useState(false);
  const [isEditing, setIsEditing] = useState(false);
  const [editableCode, setEditableCode] = useState(code);
  
  // Copy to clipboard
  const handleCopy = async () => {
    await navigator.clipboard.writeText(code);
    setCopied(true);
    setTimeout(() => setCopied(false), 2000);
  };
  
  // Handle code edit
  const handleCodeChange = (newCode: string) => {
    setEditableCode(newCode);
    onCodeChange?.(newCode);
  };
  
  return (
    <div className="code-block relative group">
      {/* Actions Bar */}
      <div className="absolute top-3 right-3 flex items-center gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
        {editable && (
          <button
            onClick={() => setIsEditing(!isEditing)}
            className="p-2 rounded-lg bg-white/10 hover:bg-white/20 transition-colors"
            aria-label="Edit code"
          >
            <Edit2 size={14} />
          </button>
        )}
        
        <button
          onClick={handleCopy}
          className="p-2 rounded-lg bg-white/10 hover:bg-white/20 transition-colors"
          aria-label="Copy code"
        >
          {copied ? <Check size={14} className="text-green-400" /> : <Copy size={14} />}
        </button>
      </div>
      
      {/* Code Display */}
      {isEditing ? (
        <textarea
          value={editableCode}
          onChange={(e) => handleCodeChange(e.target.value)}
          className="w-full h-64 p-4 bg-slate-950 text-slate-200 font-mono text-sm rounded-b-xl resize-none focus:outline-none"
          spellCheck={false}
        />
      ) : (
        <Highlight
          theme={themes.nightOwl}
          code={code.trim()}
          language={language}
        >
          {({ className, style, tokens, getLineProps, getTokenProps }) => (
            <pre
              className={`${className} p-4 overflow-x-auto rounded-b-xl`}
              style={{ ...style, margin: 0 }}
            >
              {tokens.map((line, i) => (
                <div key={i} {...getLineProps({ line })}>
                  {showLineNumbers && (
                    <span className="inline-block w-8 text-slate-600 select-none">
                      {i + 1}
                    </span>
                  )}
                  {line.map((token, key) => (
                    <span key={key} {...getTokenProps({ token })} />
                  ))}
                </div>
              ))}
            </pre>
          )}
        </Highlight>
      )}
    </div>
  );
}
```

