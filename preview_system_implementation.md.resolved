## 3. Preview Toolbar Component

```tsx
// apps/docs/src/components/preview/PreviewToolbar.tsx

import { Monitor, Tablet, Smartphone, Sun, Moon, Code, Copy } from 'lucide-react';

interface PreviewToolbarProps {
  framework: 'react' | 'vue';
  onFrameworkChange: (framework: 'react' | 'vue') => void;
  theme: 'light' | 'dark';
  onThemeChange: (theme: 'light' | 'dark') => void;
  viewport: 'mobile' | 'tablet' | 'desktop';
  onViewportChange: (viewport: 'mobile' | 'tablet' | 'desktop') => void;
  isCodeVisible: boolean;
  onToggleCode: () => void;
}

export function PreviewToolbar({
  framework,
  onFrameworkChange,
  theme,
  onThemeChange,
  viewport,
  onViewportChange,
  isCodeVisible,
  onToggleCode,
}: PreviewToolbarProps) {
  return (
    <div className="preview-toolbar flex items-center justify-between px-4 py-2 bg-slate-900/50 border-b border-white/10">
      {/* Left: Framework Selector */}
      <div className="flex items-center gap-1">
        <FrameworkButton
          active={framework === 'react'}
          onClick={() => onFrameworkChange('react')}
        >
          React
        </FrameworkButton>
        <FrameworkButton
          active={framework === 'vue'}
          onClick={() => onFrameworkChange('vue')}
        >
          Vue
        </FrameworkButton>
      </div>
      
      {/* Center: Viewport Selector */}
      <div className="flex items-center gap-1 bg-slate-800 rounded-lg p-1">
        <ViewportButton
          active={viewport === 'mobile'}
          onClick={() => onViewportChange('mobile')}
          icon={<Smartphone size={16} />}
          label="Mobile"
        />
        <ViewportButton
          active={viewport === 'tablet'}
          onClick={() => onViewportChange('tablet')}
          icon={<Tablet size={16} />}
          label="Tablet"
        />
        <ViewportButton
          active={viewport === 'desktop'}
          onClick={() => onViewportChange('desktop')}
          icon={<Monitor size={16} />}
          label="Desktop"
        />
      </div>
      
      {/* Right: Theme & Code Toggle */}
      <div className="flex items-center gap-2">
        <button
          onClick={() => onThemeChange(theme === 'light' ? 'dark' : 'light')}
          className="p-2 rounded-lg hover:bg-white/10 transition-colors"
          aria-label="Toggle theme"
        >
          {theme === 'light' ? <Moon size={16} /> : <Sun size={16} />}
        </button>
        
        <button
          onClick={onToggleCode}
          className={`p-2 rounded-lg transition-colors ${
            isCodeVisible ? 'bg-white/10' : 'hover:bg-white/10'
          }`}
          aria-label="Toggle code"
        >
          <Code size={16} />
        </button>
      </div>
    </div>
  );
}
```

---

## 4. Preview Frame (Iframe Sandbox)

```tsx
// apps/docs/src/components/preview/PreviewFrame.tsx

import { useRef, useEffect, useState } from 'react';

interface PreviewFrameProps {
  code: string;
  framework: 'react' | 'vue';
  theme: 'light' | 'dark';
  viewport: { width: number | string; height: number };
}

export function PreviewFrame({
  code,
  framework,
  theme,
  viewport,
}: PreviewFrameProps) {
  const iframeRef = useRef<HTMLIFrameElement>(null);
  const [error, setError] = useState<string | null>(null);
  
  // Generate the preview HTML
  const generatePreviewHtml = () => {
    const dependencies = getDependencies(framework);
    
    return `
<!DOCTYPE html>
<html class="${theme}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  
  <!-- Tailwind CSS -->
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          backdropBlur: {
            glass: '16px',
          },
        },
      },
    };
  </script>
  
  <!-- ZenUI Styles -->
  <style>
    ${getZenUIStyles()}
  </style>
  
  <!-- Framework Dependencies -->
  ${dependencies.scripts}
</head>
<body class="min-h-screen flex items-center justify-center p-4 ${
      theme === 'dark' 
        ? 'bg-gradient-to-br from-slate-900 to-slate-800' 
        : 'bg-gradient-to-br from-slate-100 to-white'
    }">
  <div id="root"></div>
  
  <script type="text/babel">
    ${generateRenderCode(code, framework)}
  </script>
  
  ${dependencies.runtime}
</body>
</html>
    `;
  };
  
  // Update iframe when code/theme/framework changes
  useEffect(() => {
    if (iframeRef.current) {
      try {
        const html = generatePreviewHtml();
        iframeRef.current.srcdoc = html;
        setError(null);
      } catch (e) {
        setError(e instanceof Error ? e.message : 'Preview error');
      }
    }
  }, [code, framework, theme]);
  
  return (
    <div 
      className="preview-frame-container relative"
      style={{
        width: viewport.width,
        height: viewport.height,
        maxWidth: '100%',
      }}
    >
      {error ? (
        <div className="error-overlay absolute inset-0 flex items-center justify-center bg-red-500/10 rounded-lg">
          <p className="text-red-400 text-sm">{error}</p>
        </div>
      ) : (
        <iframe
          ref={iframeRef}
          sandbox="allow-scripts allow-same-origin"
          className="w-full h-full rounded-lg border border-white/10"
          title="Component Preview"
        />
      )}
    </div>
  );
}

// Helper: Get framework-specific dependencies
function getDependencies(framework: 'react' | 'vue') {
  if (framework === 'react') {
    return {
      scripts: `
        <script src="https://unpkg.com/react@18/umd/react.development.js"></script>
        <script src="https://unpkg.com/react-dom@18/umd/react-dom.development.js"></script>
        <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
      `,
      runtime: `
        <script>
          const root = ReactDOM.createRoot(document.getElementById('root'));
          root.render(React.createElement(Demo));
        </script>
      `,
    };
  }
  
  // Vue
  return {
    scripts: `
      <script src="https://unpkg.com/vue@3/dist/vue.global.js"></script>
    `,
    runtime: `
      <script>
        Vue.createApp(Demo).mount('#root');
      </script>
    `,
  };
}

// Helper: Generate render code
function generateRenderCode(code: string, framework: 'react' | 'vue') {
  // Extract and wrap component code for preview
  return code;
}

// Helper: Get ZenUI base styles
function getZenUIStyles() {
  return `
    :root {
      --background: 0 0% 100%;
      --foreground: 222.2 84% 4.9%;
      --glass-blur: 16px;
      --glass-bg-light: rgba(255, 255, 255, 0.7);
      --glass-bg-dark: rgba(255, 255, 255, 0.05);
      --glass-border: rgba(255, 255, 255, 0.1);
    }
    
    .dark {
      --background: 222.2 84% 4.9%;
      --foreground: 210 40% 98%;
    }
    
    .glass {
      backdrop-filter: blur(var(--glass-blur));
      -webkit-backdrop-filter: blur(var(--glass-blur));
      background: var(--glass-bg-dark);
      border: 1px solid var(--glass-border);
    }
  `;
}
```

