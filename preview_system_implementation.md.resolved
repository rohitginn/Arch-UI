## 6. Example Usage in Documentation

```mdx
// apps/docs/src/pages/components/glassmorphic/glass-card.mdx

---
title: Glass Card
description: A beautiful frosted glass card with backdrop blur effect
category: glassmorphic
priority: critical
---

import { PreviewContainer } from '@/components/preview/PreviewContainer';
import { PropsTable } from '@/components/docs/PropsTable';

# Glass Card

A premium glassmorphic card component with frosted glass effect, 
perfect for creating modern, elegant interfaces.

<PreviewContainer
  componentName="glass-card"
  examples={{
    react: `
function Demo() {
  return (
    <GlassCard className="p-6 max-w-md">
      <h3 className="text-xl font-semibold text-white mb-2">
        Glass Card
      </h3>
      <p className="text-white/70">
        This card features a beautiful frosted glass effect
        with smooth animations and premium aesthetics.
      </p>
    </GlassCard>
  );
}
    `,
    vue: `
<template>
  <GlassCard class="p-6 max-w-md">
    <h3 class="text-xl font-semibold text-white mb-2">
      Glass Card
    </h3>
    <p class="text-white/70">
      This card features a beautiful frosted glass effect
      with smooth animations and premium aesthetics.
    </p>
  </GlassCard>
</template>
    `,
  }}
/>

## Installation

```bash
npx zenui add glass-card
```

