## Step 3: Create React Package

### 3.1 Setup React Package

```bash
mkdir -p packages/react/src/components/glassmorphic
cd packages/react
pnpm init
```

### 3.2 React package.json

```json
{
  "name": "@zenui/react",
  "version": "0.1.0",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./glassmorphic": {
      "import": "./dist/glassmorphic/index.mjs",
      "require": "./dist/glassmorphic/index.js"
    }
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "dependencies": {
    "@zenui/core": "workspace:*",
    "class-variance-authority": "^0.7.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  }
}
```

### 3.3 Create First Component: Glass Card

```typescript
// packages/react/src/components/glassmorphic/glass-card/glass-card.tsx

import * as React from 'react';
import { cva, type VariantProps } from 'class-variance-authority';
import { cn } from '@zenui/core';

const glassCardVariants = cva(
  // Base styles - applied to all variants
  [
    'relative',
    'rounded-2xl',
    'overflow-hidden',
    'border',
    'transition-all',
    'duration-200',
    'ease-out',
  ].join(' '),
  {
    variants: {
      // Visual variants
      variant: {
        default: [
          'bg-white/5',
          'border-white/10',
          'backdrop-blur-lg',
          'shadow-lg',
          'hover:bg-white/8',
        ].join(' '),
        bordered: [
          'bg-white/5',
          'border-2',
          'border-white/20',
          'backdrop-blur-lg',
          'hover:border-white/30',
        ].join(' '),
        gradient: [
          'bg-gradient-to-br',
          'from-white/10',
          'to-white/5',
          'border-white/10',
          'backdrop-blur-lg',
          'hover:from-white/15',
        ].join(' '),
        glow: [
          'bg-white/5',
          'border-white/10',
          'backdrop-blur-lg',
          'shadow-[0_0_30px_rgba(255,255,255,0.1)]',
          'hover:shadow-[0_0_40px_rgba(255,255,255,0.15)]',
        ].join(' '),
      },
      
      // Blur intensity
      blur: {
        sm: 'backdrop-blur-sm',
        md: 'backdrop-blur-md',
        lg: 'backdrop-blur-lg',
        xl: 'backdrop-blur-xl',
      },
      
      // Padding sizes
      size: {
        sm: 'p-4',
        md: 'p-6',
        lg: 'p-8',
        xl: 'p-10',
      },
    },
    
    // Default values
    defaultVariants: {
      variant: 'default',
      blur: 'lg',
      size: 'md',
    },
  }
);

// TypeScript interface for component props
export interface GlassCardProps
  extends React.HTMLAttributes<HTMLDivElement>,
    VariantProps<typeof glassCardVariants> {
  /** Enable scale animation on hover */
  animated?: boolean;
  /** Show shine effect on hover */
  shine?: boolean;
  /** Additional wrapper for the content */
  asChild?: boolean;
}

/**
 * GlassCard - A premium glassmorphic card component
 * 
 * @example
 * <GlassCard variant="glow" size="lg">
 *   <h2>Beautiful Card</h2>
 *   <p>With frosted glass effect</p>
 * </GlassCard>
 */
const GlassCard = React.forwardRef<HTMLDivElement, GlassCardProps>(
  (
    {
      className,
      variant,
      blur,
      size,
      animated = false,
      shine = false,
      children,
      ...props
    },
    ref
  ) => {
    return (
      <div
        ref={ref}
        className={cn(
          glassCardVariants({ variant, blur, size }),
          animated && 'hover:scale-[1.02] hover:-translate-y-1',
          shine && 'group',
          className
        )}
        {...props}
      >
        {/* Shine overlay - only rendered if shine prop is true */}
        {shine && (
          <div
            className={cn(
              'absolute inset-0 z-0',
              'opacity-0 group-hover:opacity-100',
              'bg-gradient-to-r from-transparent via-white/10 to-transparent',
              'translate-x-[-100%] group-hover:translate-x-[100%]',
              'transition-all duration-700 ease-out'
            )}
            aria-hidden="true"
          />
        )}
        
        {/* Content wrapper */}
        <div className="relative z-10">
          {children}
        </div>
      </div>
    );
  }
);

// Display name for React DevTools
GlassCard.displayName = 'GlassCard';

// Export component and variants
export { GlassCard, glassCardVariants };
```

### 3.4 Create Component Index

```typescript
// packages/react/src/components/glassmorphic/index.ts

export { GlassCard, glassCardVariants } from './glass-card/glass-card';
export type { GlassCardProps } from './glass-card/glass-card';

// Add more exports as you create components:
// export { GlassButton } from './glass-button/glass-button';
// export { GlassModal } from './glass-modal/glass-modal';
```

### 3.5 Main Package Export

```typescript
// packages/react/src/index.ts

// Glassmorphic components
export * from './components/glassmorphic';

// Re-export core utilities for convenience
export { cn } from '@zenui/core';
```

