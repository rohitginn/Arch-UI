# ZenUI - Developer Getting Started Guide
## Complete Step-by-Step Implementation

---

## Prerequisites

Before you begin, ensure you have:
- **Node.js** 18.0+ installed
- **pnpm** 8.0+ installed (`npm install -g pnpm`)
- **Git** installed
- **VS Code** (recommended) with extensions:
  - ESLint
  - Prettier
  - Tailwind CSS IntelliSense

---

## Step 1: Create Project Structure

### 1.1 Initialize Monorepo

```bash
# Create project directory
mkdir zenui
cd zenui

# Initialize pnpm workspace
pnpm init

# Create workspace configuration
```

### 1.2 Create pnpm-workspace.yaml

```yaml
# pnpm-workspace.yaml
packages:
  - 'packages/*'
  - 'apps/*'
```

### 1.3 Create Root package.json

```json
{
  "name": "zenui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.3.0",
    "prettier": "^3.2.0",
    "eslint": "^8.56.0"
  },
  "packageManager": "pnpm@8.15.0"
}
```

### 1.4 Create turbo.json

```json
{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "pipeline": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "test": {}
  }
}
```

---

## Step 2: Create Core Package

### 2.1 Setup Core Package

```bash
# Create directories
mkdir -p packages/core/src/{utils,types,constants,hooks}
cd packages/core
pnpm init
```

### 2.2 Core package.json

```json
{
  "name": "@zenui/core",
  "version": "0.1.0",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch"
  },
  "dependencies": {
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.2.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  }
}
```

### 2.3 Create cn Utility

```typescript
// packages/core/src/utils/cn.ts

import { clsx, type ClassValue } from 'clsx';
import { twMerge } from 'tailwind-merge';

/**
 * Merge class names with Tailwind CSS conflict resolution
 * @example cn('px-4 py-2', isActive && 'bg-blue-500', className)
 */
export function cn(...inputs: ClassValue[]): string {
  return twMerge(clsx(inputs));
}
```

### 2.4 Create Design Tokens

```typescript
// packages/core/src/constants/design-tokens.ts

export const designTokens = {
  // Glass effect values
  glass: {
    blur: {
      sm: '8px',
      md: '12px',
      lg: '16px',
      xl: '24px',
    },
    background: {
      light: 'rgba(255, 255, 255, 0.7)',
      dark: 'rgba(255, 255, 255, 0.05)',
    },
    border: {
      light: 'rgba(255, 255, 255, 0.3)',
      dark: 'rgba(255, 255, 255, 0.1)',
    },
    shadow: {
      sm: '0 2px 8px rgba(0, 0, 0, 0.1)',
      md: '0 4px 16px rgba(0, 0, 0, 0.12)',
      lg: '0 8px 32px rgba(0, 0, 0, 0.15)',
    },
  },
  
  // Animation durations
  duration: {
    fast: '150ms',
    normal: '200ms',
    slow: '300ms',
  },
  
  // Easing functions
  easing: {
    default: 'cubic-bezier(0.4, 0, 0.2, 1)',
    in: 'cubic-bezier(0.4, 0, 1, 1)',
    out: 'cubic-bezier(0, 0, 0.2, 1)',
    bounce: 'cubic-bezier(0.68, -0.55, 0.265, 1.55)',
  },
};
```

### 2.5 Export Everything

```typescript
// packages/core/src/index.ts

export { cn } from './utils/cn';
export { designTokens } from './constants/design-tokens';
export * from './types';
```

